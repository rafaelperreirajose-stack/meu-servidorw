PORT=19134
NODE_ENV=development
LOG_LEVEL=info
GAME_VERSION=1.70.4

# Ports for the split servers (PORT is a legacy fallback for LIVE_PORT)
LIVE_PORT=19134
LOGIN_PORT=19132
MAIN_PORT=19133
# TCP gateway / notification channel (persistent AES socket for server push)
TCP_PORT=8084
# UDP match server — the port the client dials for the realtime game server AND
# the port the Go match instance listens on (its -addr flag). Keep them identical.
GAME_SERVER_PORT=10100
# Public host:port for THIS match instance in the fleet registry (what the client
# dials). Set to <MATCH_PUBLIC_HOST>:<GAME_SERVER_PORT> for a single instance. Empty
# => the instance isn't registered and the matchmaker uses its static address.
MATCH_ADVERTISE=

# Match prepare_token signing (HS256 JWT). The TCP matchmaker signs the
# prepare_token with this secret; the Go match-server MUST be started with the
# same MATCH_JWT_SECRET to verify it. Change this for anything non-dev.
MATCH_JWT_SECRET=dev-match-secret-change-me
MATCH_JWT_TTL_SEC=600

# --- infra migration (Phase 0+) --------------------------------------------
# Redis event bus (Streams for durable commands + PubSub for presence).
REDIS_URL=redis://127.0.0.1:6379
# PostgreSQL (Phase 1+). Leave empty to keep the current SQLite store.
DATABASE_URL=postgres://ff:ff@127.0.0.1:5432/freefire?sslmode=disable
# Per-module public domains — the edge proxy routes these and they are handed to
# the client (server_url / GetLoginData / match handoff).
LIVE_DOMAIN=live.example.com
LOGIN_DOMAIN=login.example.com
MAIN_DOMAIN=main.example.com
TCP_PUBLIC_HOST=tcp.example.com
MATCH_PUBLIC_HOST=game.example.com
# This instance's id (presence + match allocation); defaults to the hostname.
NODE_ID=

# Horizontal scaling — replica counts per module (Traefik load-balances them). REQUIRES
# Postgres (DATABASE_URL): the SQLite store is single-process and can't be shared across
# replicas. The gateway is poolable too (presence + shared matchmaker + gw.push route
# pushes cross-node). The matchmaker is now leader-elected, so MATCHMAKER_REPLICAS>=2
# gives no-SPOF failover (exactly one is active). settlement scales via its shared
# consumer group (`docker compose up -d --scale settlement=N`).
LIVE_REPLICAS=1
LOGIN_REPLICAS=1
MAIN_REPLICAS=1
GATEWAY_REPLICAS=1
# Matchmaker HA: >=2 runs standby replicas that take over via the mm:leader Redis lease.
MATCHMAKER_REPLICAS=1
# Leader lease TTL (ms): the upper bound on matchmaker failover time. Renewed every ~1/3.
MM_LEASE_MS=15000
# CI deploy: seconds to let in-flight matches finish before the match instances are
# swapped (the deploy stops the matchmaker first so no NEW matches form). Also set as a
# GitHub Actions repo VARIABLE (MATCH_DRAIN_SECONDS) to override the workflow default 90.
MATCH_DRAIN_SECONDS=90

# --- docker-compose / edge (Phase 0b) --------------------------------------
# Postgres container credentials. DATABASE_URL above should match these once
# Phase 1 switches the app off SQLite (leave DATABASE_URL empty until then).
POSTGRES_USER=ff
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=freefire
# Let's Encrypt registration email — only used for the FULL edge (Traefik TLS).
ACME_EMAIL=you@example.com
# ACME CA server. Leave empty for production. While debugging certs, set to the
# staging URL to dodge rate limits (untrusted certs -> browser warning):
#   https://acme-staging-v02.api.letsencrypt.org/directory
ACME_CASERVER=
# Optional fixed public base URL handed to the client (else derived from host).
SERVER_URL=

# --- auth server (Discord-OAuth "fbconnect") -------------------------------
# Cloudflare-PROXIED domains: Traefik serves these over plain HTTP; Cloudflare
# terminates TLS (set the CF SSL mode to Flexible). Use the exact hosts the game
# client's SDK is configured to reach.
AUTH_CONNECT_DOMAIN=connect.example.com
AUTH_LOGIN_DOMAIN=login.example.com
# Internal container ports (kept as-is). AUTH_LOGIN_PORT is separate from the
# game's LOGIN_PORT so they don't collide.
CONNECT_PORT=5000
AUTH_LOGIN_PORT=25565
# Auth storage backend. The auth server now uses the SAME selector as the game
# server: if DATABASE_URL (above) is set it stores accounts in PostgreSQL, under a
# dedicated schema (AUTH_PG_SCHEMA, default `auth`) so its tables never collide
# with the game's public.accounts. Point both at one Postgres and it "just works".
# MONGO_URI/DB_NAME are the fallback and are ONLY required when DATABASE_URL is empty.
AUTH_PG_SCHEMA=auth
# MongoDB fallback (used only when DATABASE_URL is empty):
MONGO_URI=mongodb://mongo:27017
DB_NAME=libmadoka_auth
# fbconnect signed_request app id + secret.
APP_ID=2036793259884297
APP_SECRET=change-me-long-random-hex-string
# Discord OAuth app (https://discord.com/developers). The redirect URI is derived
# as https://<AUTH_LOGIN_DOMAIN>/oauth/discord/callback — register THAT on the app.
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
OAUTH_STATE_SECRET=change-me-another-long-random-hex-string
# --- login hardening (game server, src/) -----------------------------------
# Gates the game login/register against the auth server's store + the client's
# signature/version. ALL OFF or safe by default so the live (incl. guest) client
# keeps working; enable per-deployment once you know the exact client values (the
# login logs print the observed client_version + signature_md5). Requires
# DATABASE_URL pointing at the auth Postgres for the registration/ban gates.
#
# Only accounts registered on the auth server (open_id in auth.guests) may join:
AUTH_ENFORCE_REGISTRATION=false
# Also require the presented login_token to equal the auth store's access_token:
AUTH_ENFORCE_LOGIN_TOKEN=false
# Let the deterministic dev guest (GUEST_OPEN_ID) bypass the registration gate:
AUTH_ALLOW_GUEST=true
# GUEST_OPEN_ID=guest-default
# Reject clients whose client_version isn't listed (comma-separated). Empty = off:
ALLOWED_CLIENT_VERSIONS=
# Reject + TCP-kick clients whose signature_md5 isn't listed (comma-separated).
# Empty = off:
ALLOWED_SIGNATURE_MD5=
# Enforce account bans (auth.accounts.banned / authorized=false, or the game
# store's state.banned). On by default; harmless until an account is flagged.
# Ban an account with SQL, e.g.:
#   UPDATE auth.accounts SET banned = true, ban_reason = 'cheating' WHERE uid = 10000042;
AUTH_ENFORCE_BANS=true
# HTTP replay guard: drop a byte-identical resend of a recent request body to the
# same endpoint (a captured-and-replayed packet). OFF by default; enable + test
# per deployment (a client that legitimately resends identical bytes for some
# endpoint would be affected). Pairs with the login_token/Bearer-rotation and
# signature_md5 gates above. Real anti-replay would need per-request nonces the
# static-AES transport doesn't carry.
REPLAY_GUARD=false
REPLAY_WINDOW_MS=30000
# REPLAY_MAX_ENTRIES=100000
# REPLAY_EXCLUDE=LogEvent,NetworkLogEvent
